# ─── Feishu (飞书) Open Platform Credentials ─────────────────────────────────
#
# Create an app at https://open.feishu.cn/app and obtain the credentials below.
# Enable the following API scopes for your app:
#
#   Documents:
#     docx:document:readonly      - Read document content
#     docx:document.block:readonly - Read document blocks
#
#   Wiki (Knowledge Base):
#     wiki:wiki:readonly           - Read wiki spaces and nodes
#
#   Sheets (Spreadsheets):
#     sheets:spreadsheet:readonly  - Read spreadsheet metadata
#     sheets:spreadsheet.value:readonly - Read cell values
#
# After configuring scopes, add the app to the relevant wiki spaces / documents
# via "Member management" in Feishu and grant it Reader access.

FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: user access token (for content in personal spaces)
FEISHU_USER_ACCESS_TOKEN=t-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: default wiki node token for test script / direct fetch
FEISHU_WIKI_NODE_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
